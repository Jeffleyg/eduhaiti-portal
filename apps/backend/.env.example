APP_PORT=3000
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@<direct-host>:5432/postgres?sslmode=require
JWT_SECRET=change-me
JWT_EXPIRES_IN=1d
AUTH_CODE_TTL_MINUTES=10
NODE_ENV=development
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>

# Mobile money providers
MONCASH_API_URL=https://api.moncash.example/v1/charges
MONCASH_API_KEY=<moncash-api-key>
MONCASH_TIMEOUT_MS=4500
MONCASH_FEE_PERCENT=0.009

NATCASH_API_URL=https://api.natcash.example/v1/charges
NATCASH_API_KEY=<natcash-api-key>
NATCASH_TIMEOUT_MS=4500
NATCASH_FEE_PERCENT=0.0085

# Optional provider endpoints for active health checks
MONCASH_HEALTHCHECK_URL=https://api.moncash.example/health
NATCASH_HEALTHCHECK_URL=https://api.natcash.example/health
HEALTH_PROVIDER_TIMEOUT_MS=2000

# Diaspora webhook validation
DIASPORA_WEBHOOK_SECRET=<diaspora-webhook-shared-secret>
DIASPORA_WEBHOOK_MAX_SKEW_SECONDS=300
WEBHOOK_FAILURE_RATE_THRESHOLD=0.2
WEBHOOK_ALERT_MIN_SAMPLES=10
WEBHOOK_ALERT_WINDOW_SECONDS=300

# FX and remittance transparency
FX_RATE_API_URL=https://fx.example/rates
FX_RATE_TIMEOUT_MS=2000
FX_USD_TO_HTG_RATE=132
FX_EUR_TO_HTG_RATE=143.5
FX_SPREAD_PERCENT=0.0125
FX_PLATFORM_FEE_PERCENT=0.005

# Content delivery optimization
ASSET_IMAGE_MAX_WIDTH=1280
ASSET_IMAGE_QUALITY=68
AUDIO_LOW_BITRATE=48k
AUDIO_OUTPUT_DIR=uploads/audio

# Analytics / impact dashboard
SCHOLARSHIP_UNIT_HTG=15000
